#!/bin/env bash

VERSION="0.2.0-docker"

# This is a bash script that allows you to manage your bookmarks from the command line.
# It connects to the Docker container's HTTP API instead of using local files.
#
# Dependencies:
#   curl            For HTTP requests to the Docker container
#   jq              For JSON parsing (optional, for better output formatting)
#
# Environment Variables:
#   BOOKMARKS_SERVER_URL    URL of the bookmarks server (default: http://localhost:9080)
#   BOOKMARKS_DEBUG         Enable debug mode (default: false)

BOOKMARKS_SERVER_URL="${BOOKMARKS_SERVER_URL:-http://localhost:9080}"
BOOKMARKS_DEBUG="${BOOKMARKS_DEBUG:-false}"

bookmarks_log() {
    local level="$1"
    shift
    local message="$*"
    
    if [ "$BOOKMARKS_DEBUG" = "true" ] || [ "$level" = "error" ] || [ "$level" = "critical" ]; then
        echo "[$level] $message" >&2
    fi
}

bookmarks_usage() {
    echo "Usage: bookmarks [command] [options]"
    echo ""
    echo "Commands:"
    echo "  help            Show this help"
    echo "  add             Add a new bookmark [ options: --title, --uri, --category, --tags ]"
    echo "  remove [query]  Select a bookmark with fzf and remove it"
    echo "  suggest [query] Suggest bookmarks by title, tags, etc."
    echo "  open [query]    Open a bookmark in the browser"
    echo "  cd [query]      Change directory to a bookmarked folder"
    echo "  server [status] Check server status"
    echo ""
    echo "Default behavior:"
    echo "  [query]         If query matches a directory bookmark, changes to that directory"
    echo "                  If query matches a URL bookmark, opens it in the browser"
    echo ""
    echo "Options:"
    echo "  --title         Title of the bookmark"
    echo "  --uri           URI of the bookmark, can be a URL or a file path"
    echo "  --category      Category of the bookmark"
    echo "  --tags          Tags of the bookmark"
    echo "  --debug         Enable debug mode"
    echo "  --dry-run       Do not execute any command, just print what would be executed"
    echo "  [query]         Query to filter bookmarks"
    echo ""
    echo "Environment Variables:"
    echo "  BOOKMARKS_SERVER_URL    URL of the bookmarks server (default: http://localhost:9080)"
    echo "  BOOKMARKS_DEBUG         Enable debug mode (default: false)"
    echo ""
    echo "Examples:"
    echo "  bookmarks suggest \"python\""
    echo "  bookmarks add --title \"My title\" --uri \"https://example.com\" --category \"My category\" --tags \"tag1,tag2\""
    echo "  bookmarks add --title \"My Project\" --uri \"/path/to/project\" --category \"Projects\""
    echo "  bookmarks open \"my query\"  # Explicitly open URL bookmarks"
    echo "  bookmarks accounting        # Changes to directory (auto-detected)"
    echo "  bookmarks github.com        # Opens URL in browser (auto-detected)"
    echo "  b accounting                # Same as above using short alias"
    echo "  bookmarks remove github     # Select and remove bookmark by query"
}

# Check if server is available
check_server() {
    local response
    response=$(curl -s -o /dev/null -w "%{http_code}" "$BOOKMARKS_SERVER_URL/")
    if [ "$response" != "200" ]; then
        bookmarks_log error "Server not available at $BOOKMARKS_SERVER_URL"
        return 1
    fi
    return 0
}

fuzzy_search() {
    # Check if query is provided
    [ -z "$1" ] && bookmarks_log error "No query provided for fuzzy search" && return 1

    # Fetch JSON data from the server
	local request_url="$BOOKMARKS_SERVER_URL/search?q=$1&format=json"
	bookmarks_log debug "Fetching data from server with URL: $request_url"
	local response=$(curl -s "$request_url")
    
    # Validate JSON response
    if ! echo "$response" | jq empty >/dev/null 2>&1; then
        bookmarks_log error "Invalid JSON response from server"
        return 1
    fi

    # Save response to a temporary file for preview and selection
    local tmpfile=$(mktemp)
    echo "$response" > "$tmpfile"

    # id is field 1 (hidden via --with-nth=2,3), url is field 2, title is field 3
    local delimiter='|'
    local selected
    selected=$(echo "$response" | jq -r --arg d "$delimiter" \
		'.[] | "\(.id)\($d) \(.url) \($d) \(.title) \($d) \(.category) \($d) \(.tags)"' | \
        fzf -i --delimiter="$delimiter" --with-nth=2,3,4,5 \
            --preview "jq -r --arg id {1} '.[] | select(.id == \$id)' \"$tmpfile\"")

    if [ -n "$selected" ]; then
        local selected_id
        selected_id=$(echo "$selected" | cut -d"$delimiter" -f1)
        jq -r ".[] | select(.id == \"$selected_id\")" "$tmpfile"
    fi




    # Clean up temporary file
    rm -f "$tmpfile"
}

# Search all the files in the bookmarks directory for a string using fzf
# and return the list of files that contain the string
fuzzy_contents() {
    local files=$(fdfind --type f -e md . "${BOOKMARKS_DIR}")
    echo "$files" | xargs grep "" | fzf --filter="$1" | grep -o '^[^:]\+' | awk '!a[$0]++{print}'
}

get_os() {
    local os=$(uname -s)
    case "$os" in
        Linux)
            echo "linux"
            ;;
        Darwin)
            echo "mac"
            ;;
        CYGWIN*|MINGW32*|MSYS*|MINGW*)
            echo "windows"
            ;;
        *)
            echo "unknown"
            ;;
    esac
}

is_url() {
    local url="$1"
    [[ "$url" =~ ^https?:// ]]
}

is_file() {
    local uri="$1"
    is_local_file "$uri" || is_file_uri "$uri"
}

is_directory() {
    local uri="$1"
    [[ "$uri" =~ ^/ ]] || [[ "$uri" =~ ^~ ]] || [[ "$uri" =~ ^\. ]] || [[ "$uri" =~ ^\.\. ]]
}

is_file_uri() {
    [[ "$1" =~ ^file:// ]]
}

is_local_file() {
    local uri="$1"
    [[ "$uri" =~ ^/ ]] || [[ "$uri" =~ ^~ ]] || [[ "$uri" =~ ^\. ]] || [[ "$uri" =~ ^\.\. ]]
}

is_uri_accessible() {
    local uri="$1"
    bookmarks_log debug "Checking accessibility of URI: $uri"
    if is_url "$uri"; then
        http_status=$(curl $BOOKMARKS_CURL_OPTIONS --user-agent "${BOOKMARKS_USER_AGENT}" --head "$uri" | head -n 1 | grep "HTTP/[0-9.]\+ [12345].." | cut -d " " -f 2)
        bookmarks_log debug "HTTP status code: $http_status"
        # check if status code is 2xx or 3xx
        [[ "$http_status" =~ ^[23] ]] && return 0 || return 1
    elif is_file "$uri"; then
        # check if readable
        [ -r "${uri#file://}" ]
        return $?
    elif is_directory "$uri"; then
        # check if readable
        [ -r "$uri" ]
        return $?
    fi
    # unknown URI scheme, return false
    return 1
}

os_open() {
    [ -z "$1" ] && bookmarks_log critical "No URI provided" && return 1

    bookmarks_log debug "Opening $1 in browser..."
    local os=$(get_os)
    case "$os" in
        linux)
            xdg-open "$1" 2>/dev/null
            ;;
        mac)
            open "$1" 2>/dev/null
            ;;
        *)
            bookmarks_log critical "Unsuported OS: $os" && return 1
            ;;
    esac
}


# Add a new bookmark
add_bookmark() {
    local title=""
    local uri=""
    local category=""
    local tags=""
    
    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --title)
                title="$2"
                shift 2
                ;;
            --uri)
                uri="$2"
                shift 2
                ;;
            --category)
                category="$2"
                shift 2
                ;;
            --tags)
                tags="$2"
                shift 2
                ;;
            *)
                bookmarks_log error "Unknown option: $1"
                return 1
                ;;
        esac
    done
    
    # Validate required fields
    if [ -z "$uri" ]; then
        bookmarks_log error "URI is required"
        return 1
    fi
    
    if [ -z "$title" ]; then
        title="$uri"
    fi
    
    if [ -z "$category" ]; then
        category="unsorted"
    fi
    
    bookmarks_log info "Adding bookmark: $title ($uri)"
    
    # Send POST request to add bookmark
    local response
    response=$(curl -s -X POST "$BOOKMARKS_SERVER_URL/add" \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "url=$uri&title=$title&category=$category&tags=$tags")
    
    if echo "$response" | grep -q '"error"'; then
        bookmarks_log error "Failed to add bookmark: $response"
        return 1
    else
        bookmarks_log info "Bookmark added successfully"
        echo "$response"
    fi
}

# Remove a bookmark selected interactively by query
remove_bookmark() {
    local query="$1"

    if [ -z "$query" ]; then
        bookmarks_log error "Query is required"
        echo "Usage: bookmarks remove <query>"
        return 1
    fi

    local json
    json=$(fuzzy_search "$query")

    if [ -z "$json" ]; then
        bookmarks_log error "No bookmark selected"
        return 1
    fi

    local bookmark_id
    local bookmark_title
    local bookmark_url
    local bookmark_project
    local bookmark_tags
    bookmark_id=$(echo "$json" | jq -r '.id // empty')
    bookmark_title=$(echo "$json" | jq -r '.title // empty')
    bookmark_url=$(echo "$json" | jq -r '.url // empty')
    bookmark_project=$(echo "$json" | jq -r '.project // .category // empty')
    bookmark_tags=$(echo "$json" | jq -r '
        if (.tags | type) == "array" then
            (.tags | join(","))
        else
            (.tags // empty)
        end
    ')

    if [ -z "$bookmark_id" ]; then
        bookmarks_log error "Selected bookmark is missing an id"
        return 1
    fi

    echo "Selected bookmark:" >&2
    echo "  id:      $bookmark_id" >&2
    echo "  title:   $bookmark_title" >&2
    echo "  uri:     $bookmark_url" >&2
    echo "  project: $bookmark_project" >&2
    echo "  tags:    $bookmark_tags" >&2
    echo "" >&2

    local confirm
    read -r -p "Remove this bookmark? [y/N] " confirm
    case "$confirm" in
        y|Y|yes|YES)
            ;;
        *)
            bookmarks_log info "Removal canceled"
            return 0
            ;;
    esac

    bookmarks_log info "Removing bookmark id: $bookmark_id"

    # Build JSON body safely without relying on jq.
    local escaped_id
    escaped_id=$(printf '%s' "$bookmark_id" | sed 's/\\/\\\\/g; s/"/\\"/g')

    local response
    response=$(curl -s -X DELETE "$BOOKMARKS_SERVER_URL/remove" \
        -H "Content-Type: application/json" \
        -d "{\"id\":\"$escaped_id\"}")

    if echo "$response" | grep -q '"error"'; then
        bookmarks_log error "Failed to remove bookmark: $response"
        return 1
    else
        bookmarks_log info "Bookmark removed successfully"
        echo "$response"
    fi
}

# Suggest bookmarks
suggest_bookmarks() {
    local query="$1"
    
    if [ -z "$query" ]; then
        bookmarks_log error "Query is required"
        return 1
    fi
    
    # If query is shorter than 3 characters, return empty array
    if [ ${#query} -lt 3 ]; then
        echo "[]"
        return 0
    fi
    
    bookmarks_log info "Searching for: $query"
    
    # Send GET request to search bookmarks
    local response
    response=$(curl -s "$BOOKMARKS_SERVER_URL/search?q=$query&format=json")
    
    if echo "$response" | grep -q '"error"'; then
        bookmarks_log error "Search failed: $response"
        return 1
    else
        echo "$response"
    fi
}

# Open a bookmark
open_bookmark() {
    local query="$1"
    
    if [ -z "$query" ]; then
        bookmarks_log error "Query is required"
        return 1
    fi
    
    # Search for bookmarks
    local results
    results=$(suggest_bookmarks "$query")
    
    if [ $? -ne 0 ]; then
        return 1
    fi
    
    # Parse results and open the first one
    if command -v jq >/dev/null 2>&1; then
        # Use jq if available
        local url
        url=$(echo "$results" | jq -r '.[0].url // empty')
        if [ -n "$url" ]; then
            bookmarks_log info "Opening: $url"
            os_open "$url"
        else
            bookmarks_log error "No bookmarks found for: $query"
            return 1
        fi
    else
        # Fallback to grep/sed
        local url
        url=$(echo "$results" | grep -o '"url":"[^"]*"' | head -1 | sed 's/"url":"//;s/"$//')
        if [ -n "$url" ]; then
            bookmarks_log info "Opening: $url"
            os_open "$url"
        else
            bookmarks_log error "No bookmarks found for: $query"
            return 1
        fi
    fi
}

cd_bookmarks() {
    local query="$1"

    if [ -z "$query" ]; then
        bookmarks_log error "Query is required"
        return 1
    fi

    # Use fuzzy_search to get interactive selection with fzf
    local json=$(fuzzy_search "$query")
    local result=$(echo "$json" | jq -r '.url // empty')
    
    if [ -z "$result" ]; then
        bookmarks_log critical "No file found for tag: $query"
        return 1
    fi

    # Remove file:// prefix if present
    local directory=${result#file://}
    bookmarks_log info "Changing directory to: $directory"
    
    if ! is_directory "$directory"; then
        bookmarks_log critical "The URI is not a directory: $directory"
        return 1
    fi
    
    # Actually change directory - this will work because the topmost function evaluates it
    echo "cd \"$directory\""
    return 0
}

# Check server status
server_status() {
    local response
    response=$(curl -s -o /dev/null -w "%{http_code}" "$BOOKMARKS_SERVER_URL/")
    
    if [ "$response" = "200" ]; then
        echo "Server is running at $BOOKMARKS_SERVER_URL"
        return 0
    else
        echo "Server is not responding at $BOOKMARKS_SERVER_URL (HTTP $response)"
        return 1
    fi
}

# Main function
bookmarks_cmd() {
    local command="$1"
    shift
    
    case "$command" in
        help|--help|-h)
            bookmarks_usage
            return 0
            ;;
            
        add)
            if ! check_server; then
                return 1
            fi
            add_bookmark "$@"
            ;;

        remove)
            if ! check_server; then
                return 1
            fi
            remove_bookmark "$@"
            ;;
            
        suggest)
            if ! check_server; then
                return 1
            fi
            suggest_bookmarks "$@"
            ;;
            
        open)
            if ! check_server; then
                return 1
            fi
            open_bookmark "$@"
            ;;

        cd)
            if ! check_server; then
                return 1
            fi

            # Call cd_bookmarks function directly to avoid subshell issues
            cd_bookmarks "$@"
            ;;

            
        server)
            case "$1" in
                status)
                    server_status
                    ;;
                *)
                    server_status
                    ;;
            esac
            ;;
            
        *)
            local json=$(fuzzy_search "$command")
            [ -z "$json" ] && bookmarks_log critical "No file found for tag: $1" && return 1

            local uri=$(echo "$json" | jq -r '.url // empty')
            [ -z "$uri" ] && bookmarks_log critical "No URL found for tag: $1" && return 1

            # Remove file:// prefix if present for directory check
            local clean_uri=${uri#file://}
            
            # Check if this is a directory bookmark
            if is_directory "$clean_uri"; then
                # For directory bookmarks, change directory
                bookmarks_log info "Changing directory to: $clean_uri"
                echo "cd \"$clean_uri\""
            else
                # For non-directory bookmarks, open them
                # check if inside of a pipe
                if [ -t 1 ]; then
                    bookmarks_log info "Opening bookmark: $uri"
                    os_open "$uri"
                else
                    # if inside of a pipe, just echo the uri to stdout
                    echo "$uri"
                fi
            fi
            return $?
            ;;
    esac
}

# if not sourced, run main function
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    # If the script is run directly, pass all arguments to main
    bookmarks_cmd "$@"
    exit $?
fi
