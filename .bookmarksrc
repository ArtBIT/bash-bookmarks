#!/bin/env bash

SCRIPT_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" >/dev/null 2>&1 && pwd )"
export BOOKMARKS_SERVER_URL="http://192.168.82.100:9080"
export BOOKMARKS_DEBUG="true"
source $SCRIPT_DIR/bookmarks

# Wrapper function to handle cd command directly
bookmarks() {
    res=$(bookmarks_cmd "$@")
    exit_code=$?
    if [ $exit_code -eq 0 ] && [ -n "$res" ]; then
        if [[ "$res" =~ ^cd\  ]]; then
            eval "$res"
        else
            echo "$res"
        fi
    fi
}

alias b=bookmarks
